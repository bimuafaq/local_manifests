From 35567f39aaf886a51aa9c03156de02fe7ff2d0b0 Mon Sep 17 00:00:00 2001
From: Bi <133272416+bimuafaq@users.noreply.github.com>
Date: Wed, 10 Dec 2025 02:23:42 +0000
Subject: [PATCH] Introduce Force LTE_CA override on per subscription basis
 [2/3]

Patches required in:
- frameworks/base [1/3]
- frameworks/opt/telephony [2/3]
- packages/apps/settings [3/3]

Co-authored-by: Arindam Bhattacharjee <abhattacharjee717@gmail.com>
Signed-off-by: bimuafaq <bimuafaq@duck.com>
---
 .../telephony/ServiceStateTracker.java        | 24 +++++++++++++++++++
 1 file changed, 24 insertions(+)

diff --git a/src/java/com/android/internal/telephony/ServiceStateTracker.java b/src/java/com/android/internal/telephony/ServiceStateTracker.java
index 4e9217a2f0..eb5343dc2d 100755
--- a/src/java/com/android/internal/telephony/ServiceStateTracker.java
+++ b/src/java/com/android/internal/telephony/ServiceStateTracker.java
@@ -133,6 +133,10 @@
 import java.util.regex.PatternSyntaxException;
 import java.util.stream.Collectors;
 
+
+import android.database.ContentObserver;
+import android.net.Uri;
+
 /**
  * {@hide}
  */
@@ -157,6 +161,8 @@ public class ServiceStateTracker extends Handler {
 
     private boolean mVoiceCapable;
 
+    private ContentObserver mForceLteCaObserver;
+
     @UnsupportedAppUsage
     public ServiceState mSS;
     @UnsupportedAppUsage
@@ -720,6 +726,17 @@ public ServiceStateTracker(GsmCdmaPhone phone, CommandsInterface ci) {
                 CarrierServiceStateTracker.CARRIER_EVENT_DATA_DEREGISTRATION, null);
         registerForImsCapabilityChanged(mCSST,
                 CarrierServiceStateTracker.CARRIER_EVENT_IMS_CAPABILITIES_CHANGED, null);
+
+       // Force LTE CA Observer
+        mForceLteCaObserver = new ContentObserver(new Handler()) {
+            @Override
+            public void onChange(boolean selfChange) {
+                pollStateInternal(true);
+            }
+        };
+        mCr.registerContentObserver(Settings.Global.getUriFor(
+                Settings.Global.FORCE_LTE_CA + "_" + mPhone.getPhoneId()),
+                false, mForceLteCaObserver);
     }
 
     @VisibleForTesting
@@ -830,6 +847,9 @@ public void requestShutdown() {
     }
 
     public void dispose() {
+        if (mForceLteCaObserver != null) {
+           mPhone.getContext().getContentResolver().unregisterContentObserver(mForceLteCaObserver);
+        }
         mCi.unSetOnSignalStrengthUpdate(this);
         mUiccController.unregisterForIccChanged(this);
         mCi.unregisterForCellInfoList(this);
@@ -3209,6 +3229,10 @@ private void pollStateDone() {
             mNewSS.setRoaming(true);
         }
         useDataRegStateForDataOnlyDevices();
+        // Force LTE CA Logic
+        int forceLteVal = Settings.Global.getInt(mPhone.getContext().getContentResolver(),
+                Settings.Global.FORCE_LTE_CA + "_" + mPhone.getPhoneId(), 0);
+        mNewSS.setForceLteCa(forceLteVal == 1);
         processIwlanRegistrationInfo();
 
         if (TelephonyUtils.IS_DEBUGGABLE && mPhone.mTelephonyTester != null) {
