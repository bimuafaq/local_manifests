From ec0d3bee0eaf00858912291f45474393b947ec3c Mon Sep 17 00:00:00 2001
From: bimuafaq <133272416+bimuafaq@users.noreply.github.com>
Date: Mon, 29 Jun 2026 01:31:04 +0000
Subject: [PATCH] Introduce Force LTE_CA override on per subscription basis
 [3/3]

Patches required in:
- frameworks/base [1/3]
- frameworks/opt/telephony [2/3]
- packages/apps/settings [3/3]

Co-authored-by: Arindam Bhattacharjee <abhattacharjee717@gmail.com>
Change-Id: Iea03b567de6a3f1250b74c5173905eebbd6d784a
Signed-off-by: bimuafaq <bimuafaq@duck.com>
---
 res/values/custom_strings.xml                 |  4 ++++
 res/xml/mobile_network_settings.xml           |  6 ++++++
 .../telephony/MobileNetworkSettings.java      | 19 +++++++++++++++++++
 3 files changed, 29 insertions(+)

diff --git a/res/values/custom_strings.xml b/res/values/custom_strings.xml
index 22ee0ae..017688a 100644
--- a/res/values/custom_strings.xml
+++ b/res/values/custom_strings.xml
@@ -19,6 +19,10 @@
     <string name="category_screen">Screen</string>
     <string name="category_lock_interaction">Lock Screen &amp; Interaction</string>
 
+    <!-- Force LTE_CA -->
+    <string name="force_lte_ca_title">Carrier Aggregation</string>
+    <string name="force_lte_ca_summary">Enhances LTE bandwidth by aggregating supported bands.</string>
+
     <string name="gms_blocker_title">Bypass GMS Warnings</string>
     <string name="gms_blocker_summary">Bypasses the \"This app won\'t run unless you update...\" dialogs</string>
 
diff --git a/res/xml/mobile_network_settings.xml b/res/xml/mobile_network_settings.xml
index 75e1596..041182d 100644
--- a/res/xml/mobile_network_settings.xml
+++ b/res/xml/mobile_network_settings.xml
@@ -192,6 +192,12 @@
             android:dialogTitle="@string/cdma_subscription_dialogtitle"
             settings:controller="com.android.settings.network.telephony.cdma.CdmaSubscriptionPreferenceController"/>
 
+        <SwitchPreference
+           android:key="force_lte_ca"
+           android:title="@string/force_lte_ca_title"
+           android:summary="@string/force_lte_ca_summary"
+           android:persistent="false" />
+
         <PreferenceCategory
             android:key="network_operators_category_key"
             android:title="@string/network_operator_category"
diff --git a/src/com/android/settings/network/telephony/MobileNetworkSettings.java b/src/com/android/settings/network/telephony/MobileNetworkSettings.java
index 528e5c7..cdfa141 100644
--- a/src/com/android/settings/network/telephony/MobileNetworkSettings.java
+++ b/src/com/android/settings/network/telephony/MobileNetworkSettings.java
@@ -33,6 +33,7 @@ import android.view.MenuItem;
 
 import androidx.annotation.VisibleForTesting;
 import androidx.preference.Preference;
+import androidx.preference.SwitchPreference;
 
 import com.android.settings.R;
 import com.android.settings.datausage.BillingCyclePreferenceController;
@@ -62,6 +63,7 @@ public class MobileNetworkSettings extends AbstractMobileNetworkSettings {
     //String keys for preference lookup
     private static final String BUTTON_CDMA_SYSTEM_SELECT_KEY = "cdma_system_select_key";
     private static final String BUTTON_CDMA_SUBSCRIPTION_KEY = "cdma_subscription_key";
+    private static final String KEY_FORCE_LTE_CA = "force_lte_ca";
 
     private TelephonyManager mTelephonyManager;
     private int mSubId = SubscriptionManager.INVALID_SUBSCRIPTION_ID;
@@ -216,6 +218,23 @@ public class MobileNetworkSettings extends AbstractMobileNetworkSettings {
             mDropFirstSubscriptionChangeNotify = true;
         }
         mActiveSubsciptionsListener.start();
+
+        SwitchPreference forceLtePref = (SwitchPreference) findPreference(KEY_FORCE_LTE_CA);
+        if (forceLtePref != null) {
+            final int phoneId = SubscriptionManager.getSlotIndex(mSubId);
+
+            int currentVal = Settings.Global.getInt(getContext().getContentResolver(),
+                    Settings.Global.FORCE_LTE_CA + "_" + phoneId, 0);
+            forceLtePref.setChecked(currentVal == 1);
+
+            forceLtePref.setOnPreferenceChangeListener((preference, newValue) -> {
+                boolean isChecked = (Boolean) newValue;
+                Settings.Global.putInt(getContext().getContentResolver(),
+                        Settings.Global.FORCE_LTE_CA + "_" + phoneId,
+                        isChecked ? 1 : 0);
+                return true;
+            });
+        }
     }
 
     private void onSubscriptionDetailChanged() {
-- 
2.54.0

